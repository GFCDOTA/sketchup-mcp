{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "architect_answer_contract.v1",
  "title": "ArchitectAnswerContract",
  "description": "Resposta estruturada do Consult GPT. Veredito é parecer técnico, NÃO o PASS final (que é do Felipe). Nunca recomenda mover geometria congelada.",
  "type": "object",
  "required": ["question_id", "answered_at", "consultant", "verdict", "summary",
               "question_answers", "top_fix", "keep", "change", "dont_do",
               "dna_updates", "anti_patterns", "next_microtask"],
  "additionalProperties": false,
  "properties": {
    "question_id": {"type": "string", "description": "deve casar com a pergunta"},
    "answered_at": {"type": "string", "format": "date-time"},
    "consultant": {"type": "string", "default": "Consult GPT"},
    "verdict": {"type": "string", "enum": ["PASS", "WARN", "FAIL"]},
    "summary": {"type": "string", "minLength": 1, "description": "resumo do veredito em 1-3 frases"},
    "question_answers": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "verdict"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "description": "casa com questions[].id da pergunta"},
          "verdict": {"type": "string", "enum": ["PASS", "WARN", "FAIL", "N/A"]},
          "note": {"type": "string"}
        }
      }
    },
    "top_fix": {"type": "string", "minLength": 1, "description": "correção prioritária número 1 (ação objetiva)"},
    "keep": {"type": "array", "items": {"type": "string"}},
    "change": {"type": "array", "items": {"type": "string"}},
    "dont_do": {"type": "array", "items": {"type": "string"}},
    "dna_updates": {
      "type": "array",
      "items": {"type": "string"},
      "description": "regras/preferências/tokens a adicionar ao felipe_style_dna.md (dedupe no ingest)"
    },
    "anti_patterns": {"type": "array", "items": {"type": "string"}},
    "next_microtask": {
      "type": "object",
      "required": ["id", "title", "description"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "description": "MT-XXX"},
        "title": {"type": "string"},
        "description": {"type": "string"},
        "acceptance": {"type": "array", "items": {"type": "string"}},
        "likely_files": {"type": "array", "items": {"type": "string"}}
      }
    },
    "next_render_prompt": {"type": "string", "description": "direção visual curta p/ o próximo ciclo"}
  }
}
