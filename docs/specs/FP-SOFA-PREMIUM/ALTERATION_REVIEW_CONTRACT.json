{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SofaPremiumPerAlterationReview",
  "description": "Contrato obrigatório para revisão GPT antes e depois de cada alteração visual, geométrica, material, luminosa ou de posicionamento.",
  "type": "object",
  "required": [
    "alteration_id",
    "phase",
    "verdict",
    "single_instruction",
    "protected_elements",
    "evidence",
    "reasoning_summary",
    "next_change_allowed"
  ],
  "properties": {
    "alteration_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "BEFORE_CHANGE",
        "AFTER_CHANGE"
      ]
    },
    "verdict": {
      "type": "string",
      "enum": [
        "APPROVE_CHANGE",
        "REVISE_CHANGE",
        "REJECT_CHANGE",
        "IMPROVED",
        "SAME",
        "WORSE"
      ]
    },
    "defect_being_targeted": {
      "type": "string"
    },
    "proposed_change": {
      "type": "string"
    },
    "single_instruction": {
      "type": "string",
      "description": "Uma única instrução executável. Não listar múltiplas mudanças."
    },
    "protected_elements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Elementos congelados que não podem mudar neste ciclo."
    },
    "expected_visual_effect": {
      "type": "string"
    },
    "observed_visual_effect": {
      "type": "string"
    },
    "minecraft_score_before": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "minecraft_score_after": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "reasoning_summary": {
      "type": "string"
    },
    "revert_required": {
      "type": "boolean"
    },
    "next_change_allowed": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "phase": {
            "const": "BEFORE_CHANGE"
          }
        }
      },
      "then": {
        "properties": {
          "verdict": {
            "enum": [
              "APPROVE_CHANGE",
              "REVISE_CHANGE",
              "REJECT_CHANGE"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "phase": {
            "const": "AFTER_CHANGE"
          }
        }
      },
      "then": {
        "properties": {
          "verdict": {
            "enum": [
              "IMPROVED",
              "SAME",
              "WORSE"
            ]
          }
        }
      }
    }
  ]
}
