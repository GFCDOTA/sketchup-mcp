# Copy this to .env and fill in real values. .env is gitignored.

# Anthropic API key for the LLM-as-architect oracle (scripts/oracle/llm_architect.py)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the default model. Defaults to claude-opus-4-7 if unset.
# Cheaper/faster alternative: claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-7

# Optional: override max tokens for diagnosis response (default 4096)
# CLAUDE_MAX_TOKENS=4096
