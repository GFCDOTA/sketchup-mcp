__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.env
.env.*
!.env.example
.coverage
htmlcov/
dist/
build/
# runtime outputs generated by the pipeline (root-level runs/ only;
# tools/runs/ is the dashboard manifest dir and stays tracked)
/out/
/runs/
/review/
*.log
# FP-030 Visual Oracle Gate — only `final/` of each review run is
# committed; intermediate `attempt_N/` directories stay scratch
# per Constitution #8 refinement (PR #197).
artifacts/review/*/*/attempt_*/
# editor / os
.idea/
.vscode/
# .claude/ — ignore by default (local settings, projects state) but
# version the team-shared subdirs (constitution, agents, commands, hooks,
# skills, specs, memory, plans, docs, evals + CLAUDE.md + README.md +
# constitution.md). scratch/ stays ignored — it's for rascunhos
# descartáveis.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/skills/
!.claude/specs/
!.claude/memory/
!.claude/plans/
!.claude/docs/
!.claude/evals/
!.claude/settings.json
!.claude/CLAUDE.md
!.claude/README.md
!.claude/constitution.md
.DS_Store
Thumbs.db
# vendored CubiCasa5K (dev-time oracle, manual setup — see vendor/CubiCasa5k/README.md)
vendor/CubiCasa5k/weights/*.pkl
vendor/CubiCasa5k/weights/*.pth
vendor/CubiCasa5k/repo/
# keep the placeholders so the folder structure is versioned
!vendor/CubiCasa5k/.gitkeep
!vendor/CubiCasa5k/weights/.gitkeep
!vendor/CubiCasa5k/README.md

# Local triage artifacts (not tracked)
.ai_triage/

# temp / backup files — never commit
# Enforced by tools/repo_health_gate.py E001 (see docs/REPO_HYGIENE.md §5)
.tmp_*
*.tmp
*.bak
*~
*.swp
*.orig
*.rej
# SketchUp auto-backup (.skb) + per-run SU launch logs — scratch, regenerated each build
*.skb
*_place_log.txt
*_furnished_log.txt

# per-cycle repo-health JSON dumps (markdown stays tracked)
reports/current/*.json

# claude-bridge — token OAuth headless (assinatura) é SEGREDO local; NUNCA commitar
tools/claude_bridge/.oauth_token
tools/claude_bridge/*.log

# .ai_bridge: HANDOFF.md (e DECISIONS) sao versionados; questions/responses/audit/jsonl
# e dumps de consulta ao oraculo sao LOG EFEMERO local -> nao versionar.
.ai_bridge/questions/
.ai_bridge/responses/
.ai_bridge/audit/
.ai_bridge/*.jsonl
.ai_bridge/*_decision_*.md
.ai_bridge/oracle_*.md
# NOC dispatcher: ledger + lock sao runtime (queue.jsonl e' seed, versiona)
.ai_bridge/noc/actions.jsonl
.ai_bridge/noc/dispatcher.lock
# interior_studio: gaps do Auditor + ledgers dos Juizes de Render = runtime regenerado
.ai_bridge/proposals/pending/gap_*.json
.ai_bridge/interior_studio/*.jsonl
# kanban do cockpit + relay de consulta inter-agente = estado de runtime, nao fonte
.ai_bridge/kanban.json
.ai_bridge/interior_consult/

# pdf_knowledge: indice e PDFs licenciados NAO commitar
tools/pdf_knowledge/output/
references/pdfs/
*.pdf_pages.jsonl

# Furniture asset cache (3D Warehouse .skp) — licenca combined-work, nunca espelhar no repo publico
assets/third_party_cache/

# V-Ray render-element byproducts (auto-gerados por render, nao evidencia)
*.denoiser.png
*.effectsResult.png

# reference DB (índice reconstruível via reference_db.py rebuild)
artifacts/reference_lab/reference.db
artifacts/reference_lab/studio_activity.jsonl
# inbox do reference-scout = staging pre-curadoria (so INBOX.json/README.md sao versionados)
artifacts/reference_lab/inbox/*.png
artifacts/reference_lab/inbox/*.jpg
artifacts/reference_lab/inbox/*.jpeg

# project-memory RAG #2 (índice reconstruível via project_memory_db.py index)
.ai_bridge/project_memory.db
# freshness/cache do RAG do arquiteto (FP-037) — índice DERIVADO e reconstruível
# via `reference_db.py reindex`; a verdade vive nas fontes registradas.
.ai_bridge/rag_freshness.db
