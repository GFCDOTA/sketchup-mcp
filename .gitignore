__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.env
.env.*
!.env.example
.coverage
htmlcov/
dist/
build/
# runtime outputs generated by the pipeline (root-level runs/ only;
# tools/runs/ is the dashboard manifest dir and stays tracked)
/out/
/runs/
/review/
*.log
# FP-030 Visual Oracle Gate — only `final/` of each review run is
# committed; intermediate `attempt_N/` directories stay scratch
# per Constitution #8 refinement (PR #197).
artifacts/review/*/*/attempt_*/
# editor / os
.idea/
.vscode/
# .claude/ — ignore by default (local settings, projects state) but
# version the team-shared subdirs (constitution, agents, commands, hooks,
# skills, specs, memory, plans, docs, evals + CLAUDE.md + README.md +
# constitution.md). scratch/ stays ignored — it's for rascunhos
# descartáveis.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/skills/
!.claude/specs/
!.claude/memory/
!.claude/plans/
!.claude/docs/
!.claude/evals/
!.claude/settings.json
!.claude/CLAUDE.md
!.claude/README.md
!.claude/constitution.md
.DS_Store
Thumbs.db
# vendored CubiCasa5K (dev-time oracle, manual setup — see vendor/CubiCasa5k/README.md)
vendor/CubiCasa5k/weights/*.pkl
vendor/CubiCasa5k/weights/*.pth
vendor/CubiCasa5k/repo/
# keep the placeholders so the folder structure is versioned
!vendor/CubiCasa5k/.gitkeep
!vendor/CubiCasa5k/weights/.gitkeep
!vendor/CubiCasa5k/README.md

# Local triage artifacts (not tracked)
.ai_triage/

# temp / backup files — never commit
# Enforced by tools/repo_health_gate.py E001 (see docs/REPO_HYGIENE.md §5)
.tmp_*
*.tmp
*.bak
*~
*.swp
*.orig
*.rej

# per-cycle repo-health JSON dumps (markdown stays tracked)
reports/current/*.json

# claude-bridge — token OAuth headless (assinatura) é SEGREDO local; NUNCA commitar
tools/claude_bridge/.oauth_token
tools/claude_bridge/*.log

# .ai_bridge: HANDOFF.md (e DECISIONS) sao versionados; questions/responses/audit/jsonl
# e dumps de consulta ao oraculo sao LOG EFEMERO local -> nao versionar.
.ai_bridge/questions/
.ai_bridge/responses/
.ai_bridge/audit/
.ai_bridge/*.jsonl
.ai_bridge/*_decision_*.md
.ai_bridge/oracle_*.md

# pdf_knowledge: indice e PDFs licenciados NAO commitar
tools/pdf_knowledge/output/
references/pdfs/
*.pdf_pages.jsonl

# Furniture asset cache (3D Warehouse .skp) — licenca combined-work, nunca espelhar no repo publico
assets/third_party_cache/
