__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
.env
.env.*
!.env.example
.coverage
htmlcov/
dist/
build/
# runtime outputs generated by the pipeline (root-level runs/ only;
# tools/runs/ is the dashboard manifest dir and stays tracked)
/out/
/runs/
/review/
*.log
# editor / os
.idea/
.vscode/
# .claude/ — ignore by default (local settings, projects state) but
# version the team-shared subdirs (constitution, agents, commands, hooks)
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/settings.json
.DS_Store
Thumbs.db
# vendored CubiCasa5K (dev-time oracle, manual setup — see vendor/CubiCasa5k/README.md)
vendor/CubiCasa5k/weights/*.pkl
vendor/CubiCasa5k/weights/*.pth
vendor/CubiCasa5k/repo/
# keep the placeholders so the folder structure is versioned
!vendor/CubiCasa5k/.gitkeep
!vendor/CubiCasa5k/weights/.gitkeep
!vendor/CubiCasa5k/README.md
