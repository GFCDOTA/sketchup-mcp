{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FurnitureAssetManifest",
  "description": "Manifesto canonico de um movel no catalogo. Transforma um .skp aleatorio (3D Warehouse) OU um movel parametrico proprio em COMPONENTE profissional reutilizavel: escala/orientacao/anchors/clearance/qualidade conhecidos. Regra: nenhum movel principal pode ser bloco unico.",
  "type": "object",
  "required": ["id", "type", "tier", "source", "license_mode", "dimensions_m",
               "canonical_orientation", "anchors", "clearance_m", "quality"],
  "properties": {
    "id": {"type": "string", "description": "ex: sofa_kivik_dark_chaise_right_001"},
    "type": {"enum": ["sofa", "bed", "wardrobe", "nightstand", "rack", "table",
                      "chair", "lighting", "decor"]},
    "tier": {"enum": ["A_catalog", "B_curated_3dw", "C_parametric"],
             "description": "A=fabricante (entrega final); B=3DW curado/normalizado; C=parametrico proprio (fallback)"},
    "source": {"type": "string", "description": "3dwarehouse:<id/url> | parametric:<modulo> | catalog:<fabricante>"},
    "provenance": {"type": "string", "description": "URL/ID original (proveniencia); nunca espelhar o asset no repo publico"},
    "license_mode": {"enum": ["own", "combined_work_only", "manufacturer"],
                     "description": "combined_work_only = 3DW: usar dentro de entregavel combinado, NAO redistribuir standalone"},
    "variant": {"type": "string"},
    "style_tags": {"type": "array", "items": {"type": "string"}},
    "dimensions_m": {"type": "object", "required": ["width", "depth", "height"],
                     "properties": {"width": {"type": "number"}, "depth": {"type": "number"},
                                    "height": {"type": "number"}}},
    "canonical_orientation": {"type": "object", "required": ["front_axis", "up_axis"],
      "properties": {"front_axis": {"enum": ["+X", "-X", "+Y", "-Y"]},
                     "back_axis": {"enum": ["+X", "-X", "+Y", "-Y"]},
                     "up_axis": {"const": "+Z"}}},
    "anchors": {"type": "object", "description": "pontos de ancoragem em m, relativos a origem do componente (chao)",
      "properties": {"floor_origin": {"type": "array"}, "back_center": {"type": "array"},
                     "front_center": {"type": "array"}}},
    "clearance_m": {"type": "object",
      "properties": {"front": {"type": "number"}, "back": {"type": "number"},
                     "sides": {"type": "number"}, "left": {"type": "number"}, "right": {"type": "number"}}},
    "required_parts": {"type": "array", "items": {"type": "string"},
                       "description": "pecas semanticas obrigatorias (anti-bloco-unico)"},
    "parts_present": {"type": "array", "items": {"type": "string"}},
    "quality": {"type": "object",
      "required": ["scale_checked", "orientation_checked", "materials_checked", "not_single_block"],
      "properties": {"scale_checked": {"type": "boolean"}, "orientation_checked": {"type": "boolean"},
                     "materials_checked": {"type": "boolean"}, "polycount_ok": {"type": "boolean"},
                     "thumbnail_checked": {"type": "boolean"}, "not_single_block": {"type": "boolean"},
                     "gate": {"enum": ["PASS", "WARN", "FAIL", "UNVALIDATED"]}}},
    "thumbnail": {"type": "string", "description": "path relativo do thumbnail iso (gerado por nos)"},
    "renders": {"type": "object", "properties": {"top": {"type": "string"}, "front": {"type": "string"}, "iso": {"type": "string"}}},
    "skp": {"type": ["string", "null"], "description": "tier C: null (gerado por builder); tier A/B: path no third_party_cache (gitignored/privado)"},
    "builder": {"type": ["object", "null"], "description": "tier C: como reconstruir por codigo",
      "properties": {"module": {"type": "string"}, "fn": {"type": "string"}, "spec": {"type": "string"}}}
  }
}
