{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "visual_findings.v1",
  "description": "visual_findings.v1 — FP-030 base + FP-032 honesty fields (source, confidence, discriminated). All FP-032 fields are OPTIONAL so findings written before the hardening still validate. No additionalProperties:false anywhere: the runner enriches the top level with aggregation keys (oracle_verdict, final_verdict, known_warnings_carried, ...).",
  "$defs": {
    "source": {
      "description": "Where this judgment came from. oracle_bridge is the legacy/normalizer default kept for back-compat with findings written before the source enum split.",
      "enum": [
        "deterministic",
        "ollama_vision",
        "claude_bridge",
        "human",
        "oracle_bridge"
      ]
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "discriminated": {
      "description": "Did the emitting backend prove it discriminates this defect-type in the last negative_dogfood? null = not measured.",
      "type": [
        "boolean",
        "null"
      ]
    }
  },
  "required": [
    "schema_version",
    "fixture",
    "attempt",
    "top_level_verdict",
    "axes",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "visual_findings.v1"
    },
    "fixture": {
      "type": "string"
    },
    "attempt": {
      "type": "string"
    },
    "top_level_verdict": {
      "enum": [
        "PASS",
        "WARN",
        "FAIL"
      ]
    },
    "axes": {
      "type": "object"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "confidence": {
      "$ref": "#/$defs/confidence"
    },
    "discriminated": {
      "$ref": "#/$defs/discriminated"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "axis",
          "type",
          "location",
          "evidence_image",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "WARN",
              "FAIL"
            ]
          },
          "axis": {
            "enum": [
              "wall_fidelity",
              "door_fidelity",
              "window_fidelity",
              "room_fidelity",
              "scale_rotation",
              "global_visual"
            ]
          },
          "type": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "evidence_image": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "source_check": {
            "type": "string"
          },
          "suspected_owner": {
            "type": "string"
          },
          "proposed_fix": {
            "type": "string"
          },
          "source": {
            "$ref": "#/$defs/source"
          },
          "confidence": {
            "$ref": "#/$defs/confidence"
          },
          "discriminated": {
            "$ref": "#/$defs/discriminated"
          }
        }
      }
    }
  }
}
